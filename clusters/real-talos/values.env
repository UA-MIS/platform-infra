# Phase-4 (real-talos) platform variables — the portability seam (§6, D-007).
# SUPERSEDES the old clusters/real-k3s stub: Phase-4 imaging is Talos (D-024/ADR-017,
# upstream k8s), not k3s. Same three portability keys as clusters/local-k3d so the
# re-point is "fill these + point ArgoCD at the real cluster". Talos is provisioned
# out-of-band (talhelper + the runbook), so the Makefile cluster-up/down targets do
# NOT apply here — ArgoCD is pointed at the real cluster (§6 step 2).

# Real wildcard DNS base (D-007 PLATFORM_DOMAIN, pending). Drives ingress hosts +
# ACME DNS-01 (Phase 3 Cloudflare). e.g. capstone.cs.ua.edu
PLATFORM_DOMAIN=REPLACE_ME.example.edu

# Registry host on the real cluster = Harbor (Phase-2 swapped local push -> Harbor).
# e.g. harbor.capstone.cs.ua.edu/library
REGISTRY=REPLACE_ME-harbor.example.edu

# GitHub org backing AppProjects + Dex + the PR generator (unchanged unless the real
# cluster uses a different org).
GITHUB_ORG=UA-MIS

# Cluster name (talconfig clusterName) + the kubeconfig context talhelper produces.
# Talos cluster, provisioned out-of-band; not a k3d cluster.
CLUSTER_NAME=capstone

# --- Talos-specific (Phase-4) ------------------------------------------------
# Image Factory schematic ID for the 4-extension image (tailscale + iscsi-tools +
# util-linux-tools + intel-ucode). Used for the BOOT ISO (Deliverable 1 burn) and as
# a cross-check. NOTE: talconfig.yaml now declares the extensions as a `schematic`
# block (talhelper computes this same ID itself) — the INSTALLER image no longer
# depends on this var, so genconfig needs NO env export. Recorded here for the ISO
# URL + verification.
SCHEMATIC_ID=8957336bb929170959e3afc61b9088e41cb072988407edd699b9b3deb4a26972
# Pinned Talos + k8s versions (keep in sync with talconfig.yaml).
TALOS_VERSION=v1.13.4
KUBERNETES_VERSION=v1.31.5
# Overlay = "tailscale" (architect-resolved default; "kubespan" is documented-alt only).
OVERLAY=tailscale
# Tailscale node auth key = BOOTSTRAP SECRET. It is an ENV-var substitution
# (${TS_AUTHKEY} in the tailscale ExtensionServiceConfig patch), so it lives in the
# talhelper ENV file: talenv.sops.yaml (sops-encrypted) — NOT here, NOT in talsecret
# (that's the PKI secret-file), NOT plaintext talenv.yaml. genconfig auto-loads
# talenv.sops.yaml + sops-decrypts it. Reusable + tagged tag:talos-node (runbook Step 0).
# TS_AUTHKEY lives in talenv.sops.yaml (sops-encrypted), not committed here.
TS_TAG=tag:talos-node
