# Phase-4 (real-k3s) platform variables — STUB. Same keys as clusters/local-k3d
# so the re-point procedure (§6) is "fill these three values + point ArgoCD at
# the real cluster". Do not wire these until Phase 4. Placeholders are commented
# with what each must become.

# Real Cloudflare zone (D-007 PLATFORM_DOMAIN, still pending as of 2026-06-13).
# e.g. capstone.cs.ua.edu — drives ingress hosts + ACME DNS-01 (Phase 3).
PLATFORM_DOMAIN=REPLACE_ME.example.edu

# Harbor registry host on the real cluster (Phase 2 swaps local push -> Harbor).
# e.g. harbor.capstone.cs.ua.edu/library
REGISTRY=REPLACE_ME-harbor.example.edu

# Same GitHub org as Phase 1 unless the real cluster uses a different org.
GITHUB_ORG=UA-MIS

# Real-cluster context/name as known to kubeconfig. Not a k3d cluster, so the
# Makefile cluster-up/cluster-down targets do NOT apply here — real-k3s is
# provisioned out-of-band and ArgoCD is pointed at it (§6 step 2).
CLUSTER_NAME=capstone-prod
