# Phase-1 (local-k3d) platform variables — the portability seam (§6, D-007).
# These three variables are the ONLY things that differ between this target and
# the real-k3s target. Everything else (tenants, AppProjects, ApplicationSets,
# quotas, RBAC, NetworkPolicies, the app .devops/ template) is written against
# these variables, so porting = swapping clusters/<target>/values.env.

# Wildcard DNS base. *.127.0.0.1.sslip.io always resolves to 127.0.0.1 (D-003),
# so <app>.<team>.${PLATFORM_DOMAIN} reaches the host-mapped Traefik with no
# /etc/hosts edits and no DNS server. Phase 3 swaps this for the Cloudflare zone.
PLATFORM_DOMAIN=127.0.0.1.sslip.io

# Built-in k3d registry (D-005). Local CI builds and pushes here; containerd on
# every node is pre-wired to pull from it. Phase 2 swaps this for Harbor.
REGISTRY=k3d-registry.localhost:5000

# GitHub org backing the AppProject sourceRepos and the (Phase-2) PR generator.
# Resolved to UA-MIS by the human on 2026-06-13 (D-007).
GITHUB_ORG=UA-MIS

# Git base URL ArgoCD syncs from — the SINGLE SWAPPABLE repo seam. Manifests in
# bootstrap/ and applicationsets/ hardcode `https://github.com/UA-MIS/<repo>`
# (the real home). For a local T9 run where those repos aren't on UA-MIS yet,
# point this at a local/alternate host and run `make set-repo-base` to rewrite
# the repoURLs in one shot (see bootstrap/REPO-SEAM.md). Default = the real org.
GIT_BASE_URL=https://github.com/UA-MIS

# k3d cluster name (must match metadata.name in k3d-config.yaml). Consumed by the
# Makefile to derive container/context names (k3d-${CLUSTER_NAME}-*).
CLUSTER_NAME=capstone
