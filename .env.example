# platform-infra/.env.example — local developer overrides (T2).
#
# The authoritative per-cluster values live in clusters/<target>/values.env and
# are loaded by the Makefile automatically. This .env.example documents the
# variables an operator MAY override on the command line, e.g.:
#
#     make cluster-up TARGET=local-k3d
#
# You normally do NOT need a local .env — the defaults in
# clusters/local-k3d/values.env work out of the box. Copy this to .env only if
# you want personal overrides.
#
# ---------------------------------------------------------------------------
# Which target cluster directory to operate on (clusters/<TARGET>/).
#   local-k3d  -> Phase 1 k3d cluster (default)
#   real-k3s   -> Phase 4 real cluster (provisioned out-of-band; no cluster-up)
# Required: no (defaults to local-k3d). Format: directory name under clusters/.
TARGET=local-k3d

# k3d cluster name. Must match metadata.name in clusters/<target>/k3d-config.yaml.
# Used to derive container names (k3d-<name>-*) and the kube-context (k3d-<name>).
# Required: no (sourced from values.env). Format: lowercase DNS label.
CLUSTER_NAME=capstone

# Wildcard DNS base for ingress hosts (D-003). Sourced from values.env; override
# only when testing an alternate domain. Format: a hostname suffix. Dashed form
# (127-0-0-1) avoids the sslip.io dotted-IP parse collision on the preview host.
PLATFORM_DOMAIN=127-0-0-1.sslip.io

# Image registry the local CI loop pushes to (D-005). Sourced from values.env.
# Format: host:port (no scheme).
REGISTRY=k3d-registry.localhost:5000

# GitHub org for AppProject sourceRepos / PR generator (D-007). Format: org slug.
GITHUB_ORG=UA-MIS

# ---------------------------------------------------------------------------
# Container-runtime override (ADVANCED). The Makefile auto-detects rootless
# Podman and sets DOCKER_HOST/DOCKER_SOCK for k3d. Only set these by hand if
# auto-detection fails (e.g. a non-standard socket path).
#   DOCKER_HOST=unix:///run/user/1000/podman/podman.sock
#   DOCKER_SOCK=/run/user/1000/podman/podman.sock
